digraph ONNX_Graph {
  rankdir=TB; 
  node [shape=record, style=filled, fontname="Arial"];
  "bias" [shape=record, style=filled, fillcolor="#ead7b8", label="{ bias | float | 2 }"];
  "weights" [shape=record, style=filled, fillcolor="#ead7b8", label="{ weights | float | 2x2 }"];
  "final_result" [shape=record, style=filled, fillcolor="#ffffff", label="{ final_result | undef |  }"];
  "input_tensor" [shape=record, style=filled, fillcolor="#ffffff", label="{ input_tensor | float | 1x2 }"];
  "output_tensor" [shape=record, style=filled, fillcolor="#ffffff", label="{ output_tensor | undef |  }"];
  node_0 [label="{ Op: Gemm | Name: my_gemm_layer}", fillcolor="#68dede"];
  "input_tensor" -> node_0 [label="in[0]"];
  "weights" -> node_0 [label="in[1]"];
  "bias" -> node_0 [label="in[2]"];
  node_0 -> "output_tensor" [label="out[0]"];
  node_1 [label="{ Op: Relu | Name: }", fillcolor="#68dede"];
  "output_tensor" -> node_1 [label="in[0]"];
  node_1 -> "final_result" [label="out[0]"];
}
