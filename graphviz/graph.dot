digraph ONNX_Graph {
  rankdir=TB; 
  node [shape=record, style=filled, fontname="Arial"];
  "W" [shape=record, style=filled, fillcolor="#ffffff", label="{ W | undef |  }"];
  "X" [shape=record, style=filled, fillcolor="#ffffff", label="{ X | float | 1x1x5x5 }"];
  "Y" [shape=record, style=filled, fillcolor="#ffffff", label="{ Y | undef |  }"];
  node_0 [label="{ Op: Constant | Name: }", fillcolor="#68dede"];
  node_0 -> "W" [label="out[0]"];
  node_1 [label="{ Op: Conv | Name: conv_node}", fillcolor="#68dede"];
  "X" -> node_1 [label="in[0]"];
  "W" -> node_1 [label="in[1]"];
  node_1 -> "Y" [label="out[0]"];
}
